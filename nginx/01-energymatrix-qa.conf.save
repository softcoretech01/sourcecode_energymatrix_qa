server {
    listen 80;
    server_name uat.softcoretech.in;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name uat.softcoretech.in;

    ssl_certificate /etc/letsencrypt/live/uat.softcoretech.in/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/uat.softcoretech.in/privkey.pem;

    

    # 2. FRONTEND REACT
    location /energymatrix/uat/ {
        alias /usr/share/nginx/html/energymatrix/uat/;
        index index.html;
        # Change the fallback to @uat_fallback
        try_files $uri $uri/ @uat_fallback;
    }

    # New block to handle the React routing fallback correctly with alias
    location @uat_fallback {
        rewrite ^ /energymatrix/uat/index.html break;
    }

    # 3. Handle the URL without the trailing slash
    location = /energymatrix/uat {
        return 301 /energymatrix/uat/;
    }
}
